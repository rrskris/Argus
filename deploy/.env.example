# ── Argus environment variables ────────────────────────────────────────────────
# Copy this file to .env and fill in your values before running docker compose.

# PostgreSQL
POSTGRES_PASSWORD=change_me

# Control Plane secrets (generate with: openssl rand -hex 32)
ARGUS_SECRET_KEY=change_me_in_prod
ARGUS_REFRESH_SECRET_KEY=change_me_refresh_in_prod

# Admin user password (leave blank to auto-generate and print on first start)
ARGUS_ADMIN_PASSWORD=

# Enterprise license (leave blank for Community Edition)
ARGUS_LICENSE_TOKEN=

# Google OAuth (optional — leave as "mock" to use mock auth)
GOOGLE_CLIENT_ID=mock
GOOGLE_CLIENT_SECRET=mock

# Frontend URL (used for OAuth redirects and CORS)
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ClickHouse (only needed with --profile observability)
CLICKHOUSE_PASSWORD=change_me
